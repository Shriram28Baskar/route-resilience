# ── API Keys ──────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ── App Config ────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO

# ── AOI (Bengaluru demo bbox) ─────────────────────────────────
AOI_SOUTH=12.9200
AOI_WEST=77.5700
AOI_NORTH=12.9900
AOI_EAST=77.6400

# ── Model Config ──────────────────────────────────────────────
MODEL_ENCODER=resnet50
MODEL_WEIGHTS=imagenet
TILE_SIZE=512
MODEL_CHECKPOINT=data/checkpoints/best_model.pth

# ── Graph Config ──────────────────────────────────────────────
CENTRALITY_K_SAMPLES=200
ASSUMED_SPEED_KMH=30

# ── External APIs ─────────────────────────────────────────────
OVERPASS_URL=https://overpass-api.de/api/interpreter
NOMINATIM_URL=https://nominatim.openstreetmap.org
